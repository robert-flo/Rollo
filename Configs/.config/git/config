[user]
	name = Roberto Flores
	email = 25asab015@ujmd.edu.sv
    signingkey = ~/.ssh/id_ed25519.pub



[apply]
    whitespace = fix

[color]
    ui = true

[commit]
    gpgSign = true
    verbose = true

[core]
    editor = nvim
    pager = hunk pager
    excludesFile = ~/.config/git/gitignore.global
    attributesFile = ~/.config/git/gitattributes.global
    ignorecase = false
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol

[credential]
    helper = cache --timeout 3600

[diff]
    colorMoved = default
    algorithm = histogram
    mnemonicPrefix = true

[fetch]
    prune = true
    output = compact

[help]
    autocorrect = 1

[init]
    defaultBranch = master

[interactive]
    diffFilter = delta --color-only --highlight-removed

[log]
    decorate = short

[merge]
    conflictstyle = diff3
    log = true
    stat = true

[protocol]
    version = 2

[pull]
    rebase = true
    ff = only

[push]
    autoSetupRemote = true
    autoSetupRemove = true
    default = current

[rebase]
    autoStash = true
    updateRefs = true
    autoSquash = true

[include]
    path = ~/.config/git/delta.gitconfig
    path = ~/.config/git/gitconfig.local
    path = ~/.config/git/gitconfig_aliases

[delta]
    features = mantis-shrimp
[rerere]
    enabled = true
    autoupdate = true
[column]
    ui = auto
[branch]
    sort = -committerdate
[gpg]
    format = ssh

[tag]
    sort = -version:refname

# gh ssh-key add ~/.ssh/id_ed25519.pub --type signing --title "Firma de commits (SSH)"

[filter "lfs"]
    clean = git-lfs clean -- %f
    process = git-lfs filter-process
    required = true
    smudge = git-lfs smudge -- %f

[url "git@github.com:"]
    insteadOf = https://github.com/

[safe]
    directory = *
